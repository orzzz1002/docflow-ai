# DocFlow AI 环境配置示例文件
# 复制此文件为 .env 并填入实际值

# 基础配置
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000

# 日志配置
LOG_LEVEL=INFO

# 数据库配置 (PostgreSQL)
DATABASE_URL=postgresql://docflow_user:your_password@localhost:5432/docflow_db

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# AI 模型路径
AI_MODEL_PATH=./models

# 最大文档大小 (MB)
MAX_DOCUMENT_SIZE=20

# 安全配置 (生产环境务必修改)
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# API Keys (根据使用的服务填写)
# OPENAI_API_KEY=sk-xxx
# XIAOMI_MIMO_API_KEY=your_mimo_api_key
